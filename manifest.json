{
  "manifest_version": 3,
  "name": "研究报告底稿工具",
  "version": "1.0.0",
  "description": "网页截图采集、信息录入与 Excel 底稿导出工具，适用于研究人员制作工作底稿",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
